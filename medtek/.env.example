# =====================================================
# MedTek Environment Configuration Template
# =====================================================
# Copy this file to .env and fill in your actual values
# .env is gitignored and will NOT be committed to repo

# Mapbox Configuration
# Get your token from: https://account.mapbox.com/auth/signin/
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# Backend API Configuration
API_URL=http://192.168.1.56:4000

# Firebase Configuration (if using Firebase)
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id

# AI Services
# Gemini AI for pill identification
GEMINI_API_KEY=your_gemini_api_key

# Ollama Local Service (for medical triage)
OLLAMA_BASE_URL=http://192.168.1.117:8006/api/generate

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset
