# Server Configuration
PORT=4000
NODE_ENV=production

# Database Configuration
# Format: postgres://user:password@host:5432/database_name
DATABASE_URL=postgres://username:password@localhost:5432/medtek
# Set to 'true' if the database requires SSL (typical for cloud RDS/Heroku/Render)
DB_SSL=false

# Security
# Run `openssl rand -base64 32` to generate a secure secret
JWT_SECRET=your_super_secret_jwt_key_change_this

# AI Services
GEMINI_API_KEY=your_gemini_api_key_here
